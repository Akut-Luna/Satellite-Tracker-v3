# Minimum angle between current and target position before sending new command, decimal degrees  (float)
MIN_ANGLE_CHANGE_BEFORE_UPDATE = 0.5

# For performance reasons you can set the number of minutes after which the ground track gets recalculated. 
# If this is set to 0 it gets recalculated in every setp (int)
MIN_BEFORE_RECALCULATING_GROUND_TRACK = 0

# How many minutes into the future the ground track should be calculated (int)
GROUND_TRACK_STEPS = 90

# During the Artemis II mission a mismatch between the calculations for AZ/EL of this program based on Horizons 
# data, and the AZ/EL data from Horizons itself was noticed. So an option the use the AZ/EL data from Horizons
# direcly was added. (bool)
DISPLAY_HORIZONS_DIRECTLY_OPTION = True

# By default the "Start Tracking at AOS" button will be unchecked as soon as the tracking starts.
# This can be turned off by setting this variable to False.
# WARNING: Stoping the tracking maually will also uncheck the "Start Tracking at AOS" button,
# in order to prevent immediate restart of tracking. (bool)
AUTO_UNCHECK_START_TRACKING_AT_AOS_BTN = True

# The time resolution (in minutes) with which we will request data from Horizons Systems. 
# Downloading data (and in the case of the state vectors performing the calculations) can have a significant 
# impact on performance. By reducing the time resolution the performance can be improved. We interpolate between
# data points at runtime, so the impact on precision is reduced.
# Must be a minimum of 1 (int)
TIME_RESOLUTION_HORIZONS_STATE_VECTOR = 1
TIME_RESOLUTION_HORIZONS_DIRECTLY = 1